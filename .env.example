# ============================================================
# 김해장유오디감귤체험농장 - 환경변수 설정
# 이 파일을 .env.local로 복사한 후 값을 입력하세요.
# cp .env.example .env.local
# ============================================================

# 네이버 예약 위젯 ID (네이버 예약 관리자에서 확인)
# 설정하지 않으면 개발용 placeholder가 표시됩니다.
NEXT_PUBLIC_NAVER_BOOKING_ID=

# (선택) 네이버 지도 장소 ID
# 기본값: 주소 기반 검색으로 지도가 표시됩니다.
# 특정 장소 ID가 있으면 더 정확한 위치를 표시할 수 있습니다.
NEXT_PUBLIC_NAVER_MAP_SEOUL_PLACE_ID=
NEXT_PUBLIC_NAVER_MAP_BUSAN_PLACE_ID=
