# ============================================================
# 김해장유오디감귤체험농장 - 환경변수 설정
# 이 파일을 .env.local로 복사한 후 값을 입력하세요.
# cp .env.example .env.local
#
# 프로덕션에서는 Vercel 대시보드 → Settings → Environment Variables 에 등록합니다.
# ============================================================

# ----- 필수 -----

# 데이터베이스 (Vercel Postgres / Neon)
# Vercel Storage에서 DB 생성 시 자동 주입됩니다. 로컬은 vercel env pull 로 가져오세요.
POSTGRES_URL=
# (마이그레이션·시드용 — pgbouncer 없는 직접 연결)
POSTGRES_URL_NON_POOLING=

# NextAuth 시크릿 (둘 다 같은 값 권장)
# 생성: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=
# 프로덕션 URL (예: https://odifarm.co.kr)
NEXTAUTH_URL=

# 초기 관리자 계정 (seed 스크립트가 이 값으로 계정 생성)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ----- 선택 -----

# 사진 업로드 저장소 (Cloudinary). 미설정 시 어드민 사진 업로드는 비활성.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 네이버 예약 위젯 ID (네이버 예약 관리자에서 확인)
# 설정하지 않으면 개발용 placeholder가 표시됩니다.
NEXT_PUBLIC_NAVER_BOOKING_ID=

# 네이버 지도 장소 ID (없으면 주소 기반 검색으로 표시)
NEXT_PUBLIC_NAVER_MAP_SEOUL_PLACE_ID=
NEXT_PUBLIC_NAVER_MAP_BUSAN_PLACE_ID=
